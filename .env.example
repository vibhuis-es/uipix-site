# Decap CMS GitHub Configuration
# Get these from: https://github.com/settings/developers

# GitHub OAuth App Client ID
VITE_GITHUB_CLIENT_ID=your_github_client_id_here

# GitHub Repository (format: username/repo)
VITE_GITHUB_REPO=username/uipix-site

# Formspree Form ID for contact form
# Get from: https://formspree.io
VITE_FORMSPREE_ID=your_formspree_id_here

# Site Configuration
SITE_URL=https://yourdomain.com
