---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy - UiPix">
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-5 md:px-8">
      <div data-animate class="opacity-0">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight mb-4">Privacy Policy</h1>
        <p class="text-sm text-gray-400 mb-10">Last updated: March 9, 2026</p>
      </div>

      <div class="prose prose-gray max-w-none space-y-8" data-animate>
        <div class="opacity-0">
          <h2 class="text-xl font-semibold text-gray-900 mb-3">Introduction</h2>
          <p class="text-base text-gray-600 leading-relaxed">
            UiPix ("we," "our," or "us") respects your privacy. This Privacy Policy explains how we collect, use, and protect information when you visit our website at uipix.dev.
          </p>
        </div>

        <div class="opacity-0">
          <h2 class="text-xl font-semibold text-gray-900 mb-3">Information We Collect</h2>
          <p class="text-base text-gray-600 leading-relaxed mb-3">
            We collect limited information through our contact form, including:
          </p>
          <ul class="list-disc pl-5 space-y-1.5 text-base text-gray-600">
            <li>Name</li>
            <li>Email address</li>
            <li>Phone number (optional)</li>
            <li>Company name (optional)</li>
            <li>Message content</li>
          </ul>
        </div>

        <div class="opacity-0">
          <h2 class="text-xl font-semibold text-gray-900 mb-3">How We Use Your Information</h2>
          <p class="text-base text-gray-600 leading-relaxed">
            Information submitted through the contact form is used solely to respond to your inquiry. We do not sell, share, or distribute your personal information to third parties.
          </p>
        </div>

        <div class="opacity-0">
          <h2 class="text-xl font-semibold text-gray-900 mb-3">Third-Party Services</h2>
          <p class="text-base text-gray-600 leading-relaxed">
            Our contact form is processed through Formspree, a third-party form handling service. Please refer to
            <a href="https://formspree.io/legal/privacy-policy" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Formspree's Privacy Policy</a>
            for information on how they handle submitted data.
          </p>
        </div>

        <div class="opacity-0">
          <h2 class="text-xl font-semibold text-gray-900 mb-3">Cookies</h2>
          <p class="text-base text-gray-600 leading-relaxed">
            This website does not use cookies for tracking or analytics purposes. We may use essential cookies required for the website to function properly.
          </p>
        </div>

        <div class="opacity-0">
          <h2 class="text-xl font-semibold text-gray-900 mb-3">Hosting</h2>
          <p class="text-base text-gray-600 leading-relaxed">
            This website is hosted on Cloudflare Pages. Cloudflare may collect standard web server logs including IP addresses for security and performance purposes. See
            <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Cloudflare's Privacy Policy</a>
            for details.
          </p>
        </div>

        <div class="opacity-0">
          <h2 class="text-xl font-semibold text-gray-900 mb-3">Your Rights</h2>
          <p class="text-base text-gray-600 leading-relaxed">
            You may request access to, correction of, or deletion of any personal information we hold about you. To make such a request, please contact us at
            <a href="mailto:payalbhutani26@gmail.com" class="text-accent hover:underline">payalbhutani26@gmail.com</a>.
          </p>
        </div>

        <div class="opacity-0">
          <h2 class="text-xl font-semibold text-gray-900 mb-3">Changes to This Policy</h2>
          <p class="text-base text-gray-600 leading-relaxed">
            We may update this Privacy Policy from time to time. Any changes will be posted on this page with an updated revision date.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
