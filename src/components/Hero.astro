---
interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
}

const {
  title = "Hi, I'm Payal!",
  subtitle = "UX Designer focused on clarity and human-centered solutions",
  description = "I craft thoughtful digital experiences that are both functional and visually engaging. My design approach is rooted in empathy, research, and a continuous drive to learn and improve.",
  image = "/images/profile-photo.jpg",
  imageAlt = "Payal Bhutani"
} = Astro.props;
---

<section class="py-16 md:py-24 overflow-hidden">
  <div class="container-wide">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">
      <!-- Content -->
      <div data-animate class="opacity-0">
        <h1 class="mb-4 text-black">{title}</h1>
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-semibold tracking-tight text-gray-900 mb-6">{subtitle}</h2>
        <p class="text-gray-600 text-lg leading-relaxed max-w-xl">{description}</p>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes parallax {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(20px);
    }
  }

  img {
    animation: parallax 6s ease-in-out infinite;
  }
</style>
