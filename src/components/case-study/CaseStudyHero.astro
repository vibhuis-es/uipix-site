---
interface Props {
  title: string;
  subtitle: string;
  heroImage: string;
  heroImageAlt: string;
  bgImage?: string;
  duration: string;
  platform: string;
  role: string;
}

const { title, subtitle, heroImage, heroImageAlt, bgImage, duration, platform, role } = Astro.props;
const backgroundImage = bgImage || heroImage;
---

<!-- Hero -->
<section class="cs-hero relative bg-gray-950 text-white overflow-hidden">
  <div class="absolute inset-0">
    <img src={backgroundImage} alt="" class="w-full h-full object-cover opacity-25" aria-hidden="true" />
    <div class="absolute inset-0 bg-gradient-to-t from-gray-950 via-gray-950/80 to-gray-950/40"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-5 md:px-8 pt-32 pb-20 md:pt-40 md:pb-28">
    <div data-animate class="opacity-0">
      <p class="text-accent font-medium text-sm tracking-widest uppercase mb-6">Case Study</p>
      <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-semibold tracking-tight leading-[0.95] mb-4 md:mb-6">
        {title}
      </h1>
      <p class="text-lg sm:text-xl md:text-2xl text-gray-300 max-w-2xl leading-relaxed font-light">
        {subtitle}
      </p>
    </div>

    <div class="grid grid-cols-3 gap-6 sm:gap-8 mt-12 md:mt-16 max-w-lg" data-animate>
      <div class="opacity-0">
        <p class="text-[11px] font-semibold text-gray-500 uppercase tracking-widest mb-1">Duration</p>
        <p class="text-white font-medium text-sm sm:text-base">{duration}</p>
      </div>
      <div class="opacity-0">
        <p class="text-[11px] font-semibold text-gray-500 uppercase tracking-widest mb-1">Platform</p>
        <p class="text-white font-medium text-sm sm:text-base">{platform}</p>
      </div>
      <div class="opacity-0">
        <p class="text-[11px] font-semibold text-gray-500 uppercase tracking-widest mb-1">Role</p>
        <p class="text-white font-medium text-sm sm:text-base">{role}</p>
      </div>
    </div>
  </div>
</section>

<!-- Hero Image -->
<section class="bg-gray-100 py-0">
  <div class="max-w-[1400px] mx-auto px-4 md:px-8 -mt-8 relative z-20">
    <div data-animate class="opacity-0">
      <div class="rounded-xl overflow-hidden shadow-2xl ring-1 ring-black/5 bg-gray-100">
        <img
          src={heroImage}
          alt={heroImageAlt}
          class="w-full h-auto block"
          style="image-rendering: -webkit-optimize-contrast;"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .cs-hero {
    min-height: 60vh;
    display: flex;
    align-items: flex-end;
  }
  @media (min-width: 768px) {
    .cs-hero { min-height: 70vh; }
  }
</style>
