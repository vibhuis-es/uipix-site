---
interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
}

const {
  title = "Hi, I'm Payal!",
  subtitle = "UX Designer focused on clarity and human-centered solutions",
  description = "I craft thoughtful digital experiences that are both functional and visually engaging. My design approach is rooted in empathy, research, and a continuous drive to learn and improve.",
  image = "/images/profile-photo.jpg",
  imageAlt = "Payal Bhutani"
} = Astro.props;
---

<section class="py-16 md:py-24 overflow-hidden">
  <div class="container-wide">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">
      <!-- Content -->
      <div data-animate class="opacity-0">
        <h1 class="mb-4 text-black">{title}</h1>
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-semibold tracking-tight text-gray-900 mb-6">{subtitle}</h2>
        <p class="text-gray-600 text-lg leading-relaxed max-w-xl">{description}</p>
      </div>

      <!-- Decorative Graphic -->
      <div class="hidden md:flex items-center justify-center" data-animate>
        <div class="relative w-full max-w-md aspect-square">
          <!-- Floating shapes -->
          <div class="hero-shape absolute top-[8%] left-[12%] w-28 h-28 rounded-3xl bg-accent/10 rotate-12" style="animation-delay: 0s;"></div>
          <div class="hero-shape absolute top-[18%] right-[10%] w-20 h-20 rounded-full bg-accent/8" style="animation-delay: 1.2s;"></div>
          <div class="hero-shape absolute bottom-[22%] left-[8%] w-16 h-16 rounded-full bg-accent/6" style="animation-delay: 2.4s;"></div>
          <div class="hero-shape absolute bottom-[12%] right-[18%] w-24 h-24 rounded-3xl bg-accent/10 -rotate-6" style="animation-delay: 0.8s;"></div>
          <div class="hero-shape absolute top-[45%] left-[38%] w-14 h-14 rounded-2xl bg-accent/12 rotate-45" style="animation-delay: 1.8s;"></div>

          <!-- Central accent ring -->
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-44 h-44 rounded-full border-2 border-accent/15 hero-spin"></div>
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 rounded-full border border-accent/8 hero-spin-reverse"></div>

          <!-- Dot grid pattern -->
          <svg class="absolute inset-0 w-full h-full opacity-[0.12]" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <pattern id="hero-dots" x="0" y="0" width="28" height="28" patternUnits="userSpaceOnUse">
                <circle cx="2" cy="2" r="1.5" fill="#0656f6" />
              </pattern>
            </defs>
            <rect x="15%" y="15%" width="70%" height="70%" rx="24" fill="url(#hero-dots)" />
          </svg>

          <!-- Small accent dots -->
          <div class="hero-shape absolute top-[6%] right-[32%] w-3 h-3 rounded-full bg-accent/30" style="animation-delay: 0.5s;"></div>
          <div class="hero-shape absolute bottom-[30%] left-[28%] w-2.5 h-2.5 rounded-full bg-accent/25" style="animation-delay: 1.5s;"></div>
          <div class="hero-shape absolute top-[60%] right-[8%] w-3.5 h-3.5 rounded-full bg-accent/20" style="animation-delay: 2s;"></div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes heroFloat {
    0%, 100% {
      transform: translateY(0) rotate(var(--rotate, 0deg));
    }
    50% {
      transform: translateY(-12px) rotate(var(--rotate, 0deg));
    }
  }

  @keyframes heroSpin {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  @keyframes heroSpinReverse {
    from { transform: translate(-50%, -50%) rotate(360deg); }
    to { transform: translate(-50%, -50%) rotate(0deg); }
  }

  .hero-shape {
    animation: heroFloat 5s ease-in-out infinite;
  }

  .hero-spin {
    animation: heroSpin 25s linear infinite;
  }

  .hero-spin-reverse {
    animation: heroSpinReverse 35s linear infinite;
  }
</style>
