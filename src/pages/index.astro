---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const caseStudies = [
  {
    title: 'Encore',
    description: 'Hotel Financial Management Platform',
    summary: 'Replaced disconnected spreadsheets with a centralized platform for budgeting, expense tracking, and analytics across 200+ hotels.',
    role: 'UX Designer',
    industry: 'Hospitality & FinTech',
    year: '2019',
    duration: '12 weeks',
    platform: 'Web & Mobile',
    image: '/images/encore/Exe-mockup.webp',
    imageAlt: 'Encore dashboard mockup',
    href: '/work/encore',
    process: ['Research', 'IA', 'Wireframes', 'Visual Design', 'Prototype'],
    featured: true,
  },
  {
    title: 'Car Care Inc.',
    description: 'Car Repair Work Order App',
    summary: 'Designed an iPad app that reduced technician documentation time by 60% through touch-optimized workflows.',
    role: 'UX Designer',
    industry: 'Automobile',
    year: '2022',
    duration: '8 weeks',
    platform: 'iPad App',
    image: '/images/carcare/CC-ipad-mockup.png',
    imageAlt: 'Car Care iPad mockup',
    href: '/work/carcare',
    process: ['Research', 'IA', 'Wireframes', 'Visual Design', 'Prototype'],
    featured: true,
  },
  {
    title: 'Symbio6',
    description: 'Integrated Healthcare Platform & Patient Portal',
    summary: 'Designed a patient portal and mobile app that unifies health records, lab workflows, and provider connectivity - giving patients full ownership of their health data.',
    role: 'UX Designer',
    industry: 'Healthcare',
    year: '2020',
    duration: '12 weeks',
    platform: 'Web & Mobile',
    image: '/images/symbio6/heroshot.png',
    imageAlt: 'mybioX - Patient Portal on MacBook',
    href: '/work/symbio6',
    process: ['Research', 'IA', 'Wireframes', 'Visual Design', 'Mobile App'],
    featured: true,
  },
];

const featured = caseStudies.filter(s => s.featured);
const other = caseStudies.filter(s => !s.featured);
---

<BaseLayout title="Work">
  <!-- Hero Section -->
  <Hero />

  <!-- Featured Work Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">
      <div data-animate class="opacity-0 mb-10 md:mb-14">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-semibold tracking-tight text-gray-900">Latest Work</h2>
        <p class="text-gray-600 mt-3 sm:mt-4 max-w-2xl text-base sm:text-lg leading-relaxed">
          A selection of recent projects where I designed digital experiences that solve real problems through research-driven and human-centered approaches.
        </p>
      </div>

      <!-- Featured Case Studies -->
      <div class="space-y-8 sm:space-y-10 mb-10 sm:mb-12">
        {featured.map((study, index) => (
          <a href={study.href} class="group block" data-animate>
            <div class={`grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-10 items-center bg-gray-50 rounded-2xl overflow-hidden border border-gray-100 hover:border-gray-200 hover:shadow-lg transition-all duration-300 ${index % 2 === 1 ? 'lg:direction-rtl' : ''}`}>
              <!-- Image -->
              <div class="relative overflow-hidden bg-gray-100 aspect-[16/10]">
                <img
                  src={study.image}
                  alt={study.imageAlt}
                  class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
                />
              </div>

              <!-- Content -->
              <div class="p-6 sm:p-8 lg:p-10" style={index % 2 === 1 ? 'direction: ltr;' : ''}>
                <!-- Process tags -->
                {study.process.length > 0 && (
                  <div class="flex flex-wrap gap-2 mb-4">
                    {study.process.map((step) => (
                      <span class="text-[10px] sm:text-xs font-medium text-accent bg-accent/8 px-2.5 py-1 rounded-full uppercase tracking-wider">
                        {step}
                      </span>
                    ))}
                  </div>
                )}

                <h3 class="text-xl sm:text-2xl md:text-3xl font-semibold mb-2 sm:mb-3 group-hover:text-accent transition-colors">
                  {study.title}
                </h3>
                <p class="text-gray-500 text-sm sm:text-base font-medium mb-3 sm:mb-4">{study.description}</p>
                <p class="text-gray-600 text-sm sm:text-base leading-relaxed mb-5 sm:mb-6">{study.summary}</p>

                <!-- Meta -->
                <div class="flex flex-wrap gap-x-6 gap-y-2 text-xs sm:text-sm text-gray-400">
                  <div>
                    <span class="text-gray-900 font-medium">{study.role}</span>
                  </div>
                  {study.duration && (
                    <div>{study.duration}</div>
                  )}
                  {study.platform && (
                    <div>{study.platform}</div>
                  )}
                </div>

                <!-- Arrow -->
                <div class="mt-5 sm:mt-6">
                  <span class="inline-flex items-center gap-2 text-accent font-medium text-sm group-hover:gap-3 transition-all">
                    View Case Study
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                    </svg>
                  </span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Other Projects (coming soon, etc.) -->
      {other.length > 0 && (
        <div data-animate class="opacity-0">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
            {other.map((study) => (
              <a href={study.href} class="group">
                <div class="bg-white border border-gray-100 rounded-xl overflow-hidden hover:border-gray-200 hover:shadow-md transition-all duration-300 h-full">
                  <div class="relative overflow-hidden bg-gray-100 aspect-video">
                    <img
                      src={study.image}
                      alt={study.imageAlt}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                  </div>
                  <div class="p-5 sm:p-6">
                    <h3 class="text-lg sm:text-xl font-semibold mb-1 sm:mb-2 group-hover:text-accent transition-colors">
                      {study.title}
                    </h3>
                    <p class="text-gray-600 text-sm sm:text-base leading-relaxed mb-3">{study.description}</p>
                    <div class="flex flex-wrap gap-3 text-xs text-gray-400">
                      <span>{study.role}</span>
                      <span>{study.industry}</span>
                      <span>{study.year}</span>
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-24 bg-black text-white">
    <div class="max-w-3xl mx-auto px-5 md:px-8 text-center" data-animate>
      <h2 class="text-white text-2xl sm:text-3xl md:text-4xl font-semibold tracking-tight mb-4 sm:mb-6">Let's work together</h2>
      <p class="text-gray-300 mb-6 sm:mb-8 text-base sm:text-lg leading-relaxed">
        I'm always open to discussing new projects, creative ideas, or opportunities to be part of your vision.
      </p>
      <a
        href="/contact"
        class="inline-block px-6 sm:px-8 py-3 sm:py-4 bg-accent hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors duration-300 text-sm sm:text-base"
      >
        Get in Touch
      </a>
    </div>
  </section>
</BaseLayout>
