---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseStudyHero from '../../components/case-study/CaseStudyHero.astro';
import SectionHeader from '../../components/case-study/SectionHeader.astro';
import ProcessBar from '../../components/case-study/ProcessBar.astro';
import ComparisonGrid from '../../components/case-study/ComparisonGrid.astro';
import MetricCards from '../../components/case-study/MetricCards.astro';
import VideoEmbed from '../../components/case-study/VideoEmbed.astro';
import ScreenGallery from '../../components/case-study/ScreenGallery.astro';
import CaseStudyNav from '../../components/case-study/CaseStudyNav.astro';

const hifiScreens = [
  { src: '/images/carcare/Work-orders.png', alt: 'Work Orders Dashboard', title: 'Work Orders', desc: 'Dashboard showing all active work orders with status badges and quick actions' },
  { src: '/images/carcare/Check-in.png', alt: 'Vehicle Check-in', title: 'Check-in', desc: 'VIN scanner auto-populates vehicle details, reducing manual data entry' },
  { src: '/images/carcare/Complaints.png', alt: 'Complaint Capture', title: 'Complaints', desc: 'Pre-populated complaint categories with tap-to-select, eliminating typing' },
  { src: '/images/carcare/Diagnosis.png', alt: 'Diagnosis & Findings', title: 'Diagnosis', desc: 'Visual documentation with photo annotation and voice notes for low-typing workflows' },
  { src: '/images/carcare/Parts.png', alt: 'Parts & Inventory', title: 'Parts', desc: 'Real-time stock visibility with supplier comparison and one-tap adding' },
  { src: '/images/carcare/Estimate.png', alt: 'Cost Estimate', title: 'Estimate', desc: 'Auto-calculated estimate with adjustable labor hours and transparent pricing' },
  { src: '/images/carcare/Review.png', alt: 'Customer Review', title: 'Review', desc: 'Visual proof with plain-language explanations and digital signature capture' },
  { src: '/images/carcare/Complete.png', alt: 'Job Complete', title: 'Complete', desc: 'Final invoice with payment method selection and completion signature' },
];

const wireframeScreens = [
  { title: 'Screen 01', name: 'Home / Active Work Orders', desc: 'Dashboard showing all active jobs for quick access and status visibility.' },
  { title: 'Screen 02', name: 'Vehicle Intake', desc: 'Quickly capture vehicle details using VIN scan with auto-fill capabilities.' },
  { title: 'Screen 03', name: 'Customer Complaint Capture', desc: 'Record initial customer complaint using quick-select or voice input.' },
  { title: 'Screen 04', name: 'Technician Diagnosis & Findings', desc: 'Document actual problems found using structured fault selection and photo capture.' },
  { title: 'Screen 05', name: 'Repair Actions & Parts', desc: 'Select repair procedures and required parts with integrated catalog and pricing.' },
  { title: 'Screen 06', name: 'Repair Summary & Estimate', desc: 'Complete cost breakdown ready for customer review with automatic totals.' },
  { title: 'Screen 07', name: 'Customer Approval', desc: 'Customer-facing view with digital signature capture for work authorization.' },
  { title: 'Screen 08', name: 'Job Completion & Billing', desc: 'Final invoice generation and work order closure with automated billing.' },
];
---

<BaseLayout title="Car Care Inc. - Work Order Application">

  <!-- HERO -->
  <CaseStudyHero
    title="Car Care Inc."
    subtitle="Car Repair Work Order Application"
    heroImage="/images/carcare/CC-ipad-mockup.png"
    heroImageAlt="Car Care iPad Mockup"
    duration="8 weeks"
    platform="iPad App"
    role="UX Designer"
  />

  <!-- PROCESS BAR -->
  <ProcessBar steps={['Overview', 'Research', 'IA & Flows', 'Wireframes', 'Visual Design', 'Prototype', 'Outcomes']} />

  <!-- ══════════════════════════════════════════════ -->
  <!-- 01 · OVERVIEW                                  -->
  <!-- ══════════════════════════════════════════════ -->
  <section id="section-0" class="py-16 md:py-24 bg-gray-100">
    <div class="max-w-3xl mx-auto px-5 md:px-8">
      <SectionHeader
        step="01"
        label="Overview"
        title="Digitizing the repair workflow"
      />
      <div data-animate class="opacity-0">
        <p class="text-gray-700 text-base sm:text-lg leading-relaxed mb-6">
          Car Care Inc. needed a purpose-built iPad app for their auto repair technicians. The goal was to replace paper-based work orders and fragmented desktop tools with a single, touch-optimized application that follows the natural repair workflow - from vehicle check-in to customer sign-off and billing.
        </p>
        <p class="text-gray-500 text-base sm:text-lg leading-relaxed">
          I led the UX design over 8 weeks, from user research and competitive analysis through wireframes, visual design, and an interactive prototype. The result: an app that reduced documentation time by 60%.
        </p>
      </div>
    </div>
  </section>

  <!-- Problem Statement -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-5 md:px-8">
      <div data-animate class="opacity-0">
        <p class="text-[11px] font-semibold text-accent uppercase tracking-widest mb-4">The Problem</p>
        <p class="text-gray-900 text-lg sm:text-xl md:text-2xl leading-relaxed font-light">
          Senior technicians spend 30–45 minutes per work order typing vehicle details, diagnoses, and customer communications - taking them away from actual repair work.
        </p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════ -->
  <!-- 02 · RESEARCH & DISCOVERY                      -->
  <!-- ══════════════════════════════════════════════ -->
  <section id="section-1" class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-5xl mx-auto px-5 md:px-8">
      <SectionHeader
        step="02"
        label="Research & Discovery"
        title="Industry pain points & UX opportunities"
      />

      <div class="max-w-4xl">
        <ComparisonGrid
          leftLabel="Pain Points"
          leftItems={[
            'Too much manual documentation - technicians spend significant time writing repair notes',
            'Repeating the same information - common issues documented from scratch every time',
            'Switching between systems - paper forms, desktop software, and digital tools break flow',
            'Slow customer approvals - waiting for customers creates idle time',
            'Parts lookup friction - multiple steps and system switches required',
          ]}
          rightLabel="UX Opportunities"
          rightItems={[
            'Guided workflows - step-by-step flows that reduce decisions and mental load',
            'Quick-select inputs - pre-populated options for common repairs and parts',
            'Visual documentation - photo capture and annotation to minimize typing',
            'Real-time summaries - auto-generated customer-facing summaries from technician input',
            'Digital sign-off - in-app approval flow to eliminate delays and paper',
          ]}
        />
      </div>
    </div>
  </section>

  <!-- Design Goals -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-5 md:px-8">
      <SectionHeader label="Design Goals" title="Three core principles" />
      <div data-animate class="opacity-0">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 sm:gap-6">
          <div class="bg-gray-50 rounded-xl p-5 sm:p-6 border border-gray-200">
            <div class="w-8 h-8 rounded-lg bg-accent/10 flex items-center justify-center mb-4">
              <span class="text-accent font-bold text-sm">01</span>
            </div>
            <p class="font-semibold text-gray-900 mb-2 text-base">Minimize Typing</p>
            <p class="text-sm sm:text-base text-gray-500 leading-relaxed">VIN scan + smart templates to cut manual entry drastically.</p>
          </div>
          <div class="bg-gray-50 rounded-xl p-5 sm:p-6 border border-gray-200">
            <div class="w-8 h-8 rounded-lg bg-accent/10 flex items-center justify-center mb-4">
              <span class="text-accent font-bold text-sm">02</span>
            </div>
            <p class="font-semibold text-gray-900 mb-2 text-base">Fast Customer Sign-off</p>
            <p class="text-sm sm:text-base text-gray-500 leading-relaxed">Photos + digital signature for fully paperless approval workflows.</p>
          </div>
          <div class="bg-gray-50 rounded-xl p-5 sm:p-6 border border-gray-200">
            <div class="w-8 h-8 rounded-lg bg-accent/10 flex items-center justify-center mb-4">
              <span class="text-accent font-bold text-sm">03</span>
            </div>
            <p class="font-semibold text-gray-900 mb-2 text-base">Work Offline</p>
            <p class="text-sm sm:text-base text-gray-500 leading-relaxed">Sync automatically when connected. Zero data loss in the workshop.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Competitive Audit -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-5xl mx-auto px-5 md:px-8">
      <SectionHeader label="Competitive Audit" title="Landscape analysis" />
      <div data-animate class="opacity-0">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8 sm:mb-10">
          <div class="bg-white rounded-xl p-4 sm:p-5 hover:bg-gray-100 transition-colors border border-gray-100">
            <p class="font-semibold text-gray-900 mb-1 text-sm sm:text-base">Shopmonkey</p>
            <p class="text-xs sm:text-sm text-gray-500">Mobile technician tools, digital inspections with photos</p>
          </div>
          <div class="bg-white rounded-xl p-4 sm:p-5 hover:bg-gray-100 transition-colors border border-gray-100">
            <p class="font-semibold text-gray-900 mb-1 text-sm sm:text-base">Tekmetric</p>
            <p class="text-xs sm:text-sm text-gray-500">VIN scanning, mobile check-in workflows</p>
          </div>
          <div class="bg-white rounded-xl p-4 sm:p-5 hover:bg-gray-100 transition-colors border border-gray-100">
            <p class="font-semibold text-gray-900 mb-1 text-sm sm:text-base">RepairShopr</p>
            <p class="text-xs sm:text-sm text-gray-500">Touchscreen signatures on invoices</p>
          </div>
          <div class="bg-white rounded-xl p-4 sm:p-5 hover:bg-gray-100 transition-colors border border-gray-100">
            <p class="font-semibold text-gray-900 mb-1 text-sm sm:text-base">Mitchell 1</p>
            <p class="text-xs sm:text-sm text-gray-500">Deep parts catalog integration</p>
          </div>
        </div>
      </div>

      <div data-animate class="opacity-0">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Opportunities to Improve</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="bg-white rounded-lg p-4 border border-gray-100">
            <p class="text-gray-700 text-sm sm:text-base">Fewer taps: Quick-select complaint chips vs. open text fields</p>
          </div>
          <div class="bg-white rounded-lg p-4 border border-gray-100">
            <p class="text-gray-700 text-sm sm:text-base">Voice notes for techs with low typing comfort</p>
          </div>
          <div class="bg-white rounded-lg p-4 border border-gray-100">
            <p class="text-gray-700 text-sm sm:text-base">Offline-first architecture and plain-language customer summaries</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Persona -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-5 md:px-8">
      <SectionHeader
        label="Primary User"
        title="Meet Bob - Senior Technician"
        description="15 years experience. Values efficiency over features. The interface must feel intuitive from the first tap."
      />

      <div data-animate class="opacity-0 mb-8 sm:mb-10">
        <div class="rounded-xl overflow-hidden border border-gray-200 shadow-sm max-w-4xl mx-auto">
          <img src="/images/carcare/Bob-Persona.webp" alt="Bob - Senior Technician Persona" class="w-full h-auto block" />
        </div>
      </div>

      <div data-animate class="opacity-0">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="bg-gray-50 rounded-xl p-5 border border-gray-200">
            <p class="text-[11px] font-semibold text-green-600 uppercase tracking-widest mb-3">Goals</p>
            <ul class="space-y-2 text-sm sm:text-base text-gray-600">
              <li>Complete work orders fast</li>
              <li>Document with photos</li>
              <li>Easy customer sign-off</li>
            </ul>
          </div>
          <div class="bg-gray-50 rounded-xl p-5 border border-gray-200">
            <p class="text-[11px] font-semibold text-red-500 uppercase tracking-widest mb-3">Frustrations</p>
            <ul class="space-y-2 text-sm sm:text-base text-gray-600">
              <li>Too much typing</li>
              <li>Offline access failures</li>
              <li>Repeat data entry</li>
            </ul>
          </div>
          <div class="bg-gray-50 rounded-xl p-5 border border-gray-200">
            <p class="text-[11px] font-semibold text-accent uppercase tracking-widest mb-3">Design Implication</p>
            <p class="text-sm sm:text-base text-gray-600 leading-relaxed">Bob needs maximum efficiency with minimal learning curve. Success means completing documentation faster than his current method, without feeling like he's "learning software."</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════ -->
  <!-- 03 · INFORMATION ARCHITECTURE & FLOWS          -->
  <!-- ══════════════════════════════════════════════ -->
  <section id="section-2" class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-5xl mx-auto px-5 md:px-8">
      <SectionHeader
        step="03"
        label="Information Architecture"
        title="Technician workflow overview"
        description="Breaking down Bob's daily workflow into four key task flows the iPad app must support."
      />

      <div data-animate class="opacity-0 mb-8 sm:mb-10">
        <div class="rounded-xl overflow-hidden border border-gray-200 shadow-sm">
          <img src="/images/carcare/workflows.webp" alt="Technician Workflow Overview" class="w-full h-auto block" />
        </div>
      </div>

      <div data-animate class="opacity-0">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5">
          <div class="bg-white rounded-xl p-5 border border-gray-200">
            <p class="text-accent font-bold text-xs mb-2">Flow A</p>
            <p class="font-semibold text-gray-900 mb-1 text-base">Quick Check-in</p>
            <p class="text-sm sm:text-base text-gray-500">VIN/Plate Scan → Auto-fill Vehicle Details</p>
          </div>
          <div class="bg-white rounded-xl p-5 border border-gray-200">
            <p class="text-accent font-bold text-xs mb-2">Flow B</p>
            <p class="font-semibold text-gray-900 mb-1 text-base">Diagnosis</p>
            <p class="text-sm sm:text-base text-gray-500">Quick-select Faults → Photos + Voice Note</p>
          </div>
          <div class="bg-white rounded-xl p-5 border border-gray-200">
            <p class="text-accent font-bold text-xs mb-2">Flow C</p>
            <p class="font-semibold text-gray-900 mb-1 text-base">Customer Review</p>
            <p class="text-sm sm:text-base text-gray-500">Photos + Estimate → Digital Signature</p>
          </div>
          <div class="bg-white rounded-xl p-5 border border-gray-200">
            <p class="text-accent font-bold text-xs mb-2">Flow D</p>
            <p class="font-semibold text-gray-900 mb-1 text-base">Complete Job</p>
            <p class="text-sm sm:text-base text-gray-500">Auto-generate Invoice → Payment Signature</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- UX Design Principles -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-5 md:px-8">
      <SectionHeader
        label="Design Direction"
        title="UX design principles"
        description="Core principles guiding every design decision for the workshop environment."
      />

      <div data-animate class="opacity-0">
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          <div class="bg-gray-50 rounded-xl p-4 sm:p-5 border border-gray-200">
            <div class="w-9 h-9 rounded-lg bg-accent/10 flex items-center justify-center mb-3">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M12 19l7-7 3 3-7 7-3-3z"></path><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"></path><path d="M2 2l7.586 7.586"></path><circle cx="11" cy="11" r="2"></circle></svg>
            </div>
            <p class="font-semibold text-gray-900 mb-1 text-sm sm:text-base">Minimize Typing</p>
            <p class="text-xs sm:text-sm text-gray-500 mb-2">Smart defaults, pre-populated options, voice input</p>
            <ul class="text-xs text-gray-400 space-y-1">
              <li>Quick-select menus for common repairs</li>
              <li>Auto-complete for parts and services</li>
              <li>Template-based descriptions</li>
            </ul>
          </div>
          <div class="bg-gray-50 rounded-xl p-4 sm:p-5 border border-gray-200">
            <div class="w-9 h-9 rounded-lg bg-accent/10 flex items-center justify-center mb-3">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            </div>
            <p class="font-semibold text-gray-900 mb-1 text-sm sm:text-base">Maximize Quick-Select</p>
            <p class="text-xs sm:text-sm text-gray-500 mb-2">Taps, toggles, and selections over typing</p>
            <ul class="text-xs text-gray-400 space-y-1">
              <li>Checkbox lists for common issues</li>
              <li>Visual part selectors</li>
              <li>One-tap status updates</li>
            </ul>
          </div>
          <div class="bg-gray-50 rounded-xl p-4 sm:p-5 border border-gray-200">
            <div class="w-9 h-9 rounded-lg bg-accent/10 flex items-center justify-center mb-3">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><line x1="12" y1="20" x2="12" y2="10"></line><line x1="18" y1="20" x2="18" y2="4"></line><line x1="6" y1="20" x2="6" y2="16"></line></svg>
            </div>
            <p class="font-semibold text-gray-900 mb-1 text-sm sm:text-base">Guided Workflow</p>
            <p class="text-xs sm:text-sm text-gray-500 mb-2">Clear direction at every stage</p>
            <ul class="text-xs text-gray-400 space-y-1">
              <li>Step-by-step indicators</li>
              <li>Clear next action buttons</li>
              <li>Progress visualization</li>
            </ul>
          </div>
          <div class="bg-gray-50 rounded-xl p-4 sm:p-5 border border-gray-200">
            <div class="w-9 h-9 rounded-lg bg-accent/10 flex items-center justify-center mb-3">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            </div>
            <p class="font-semibold text-gray-900 mb-1 text-sm sm:text-base">Reduce Cognitive Load</p>
            <p class="text-xs sm:text-sm text-gray-500 mb-2">Simplify decisions, minimize on-screen options</p>
            <ul class="text-xs text-gray-400 space-y-1">
              <li>Show only relevant options per step</li>
              <li>Smart field ordering</li>
              <li>Hide advanced features by default</li>
            </ul>
          </div>
          <div class="bg-gray-50 rounded-xl p-4 sm:p-5 border border-gray-200">
            <div class="w-9 h-9 rounded-lg bg-accent/10 flex items-center justify-center mb-3">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
            </div>
            <p class="font-semibold text-gray-900 mb-1 text-sm sm:text-base">Workshop-Ready</p>
            <p class="text-xs sm:text-sm text-gray-500 mb-2">Gloves, bright lights, outdoor conditions</p>
            <ul class="text-xs text-gray-400 space-y-1">
              <li>Large touch targets (48px minimum)</li>
              <li>High contrast UI elements</li>
              <li>No small text or controls</li>
            </ul>
          </div>
          <div class="bg-gray-50 rounded-xl p-4 sm:p-5 border border-gray-200">
            <div class="w-9 h-9 rounded-lg bg-accent/10 flex items-center justify-center mb-3">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
            </div>
            <p class="font-semibold text-gray-900 mb-1 text-sm sm:text-base">Fail-Safe Documentation</p>
            <p class="text-xs sm:text-sm text-gray-500 mb-2">Never lose data, auto-save frequently</p>
            <ul class="text-xs text-gray-400 space-y-1">
              <li>Auto-save every action</li>
              <li>Offline capability</li>
              <li>Clear save status indicators</li>
            </ul>
          </div>
        </div>
      </div>

      <div data-animate class="opacity-0 mt-6 sm:mt-8">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
          <div class="bg-accent/5 rounded-xl p-4 sm:p-5 border border-accent/20">
            <div class="flex items-center gap-2 mb-2">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
              <p class="font-semibold text-accent text-sm sm:text-base">Speed First</p>
            </div>
            <p class="text-xs text-gray-500">Every interaction optimized for the fastest possible completion time</p>
          </div>
          <div class="bg-accent/5 rounded-xl p-4 sm:p-5 border border-accent/20">
            <div class="flex items-center gap-2 mb-2">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              <p class="font-semibold text-accent text-sm sm:text-base">Zero Learning Curve</p>
            </div>
            <p class="text-xs text-gray-500">Intuitive enough to use immediately without training or documentation</p>
          </div>
          <div class="bg-accent/5 rounded-xl p-4 sm:p-5 border border-accent/20">
            <div class="flex items-center gap-2 mb-2">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
              <p class="font-semibold text-accent text-sm sm:text-base">Workshop-Ready</p>
            </div>
            <p class="text-xs text-gray-500">Designed specifically for the physical constraints of automotive repair environments</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- User Journey Map -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-5xl mx-auto px-5 md:px-8">
      <SectionHeader
        label="User Journey Mapping"
        title="End-to-end: Check-in to billing"
