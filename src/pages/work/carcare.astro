  <script>
    function initHifiCarousels() {
      document.querySelectorAll('[data-hifi-carousel]').forEach((el) => {
        const carousel = el as HTMLElement;
        if (carousel.dataset.hifiInit) return;
        carousel.dataset.hifiInit = 'true';

        const track = carousel.querySelector('[data-hifi-track]') as HTMLElement;
        const pages = carousel.querySelectorAll('[data-hifi-page]') as NodeListOf<HTMLElement>;
        const dots = carousel.querySelectorAll('[data-hifi-dot]') as NodeListOf<HTMLElement>;
        const prevBtn = carousel.querySelector('.hifi-prev') as HTMLElement;
        const nextBtn = carousel.querySelector('.hifi-next') as HTMLElement;

        // Filter to only even-indexed pages (each contains 2 screens)
        const totalPages = 4;
        let current = 0;

        function goTo(index: number) {
          current = index;
          track.style.transform = `translateX(-${index * 100}%)`;
          dots.forEach((d, i) => {
            d.classList.toggle('bg-accent', i === index);
            d.classList.toggle('w-6', i === index);
            d.classList.toggle('bg-gray-600', i !== index);
            d.classList.toggle('w-2', i !== index);
          });
        }

        prevBtn?.addEventListener('click', () => goTo((current - 1 + totalPages) % totalPages));
        nextBtn?.addEventListener('click', () => goTo((current + 1) % totalPages));
        dots.forEach((d) => {
          d.addEventListener('click', () => goTo(parseInt(d.dataset.hifiDot || '0')));
        });
      });
    }
    initHifiCarousels();
    document.addEventListener('astro:page-load', initHifiCarousels);
  </script>

