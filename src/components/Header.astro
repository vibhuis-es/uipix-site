---
const currentPath = new URL(Astro.request.url).pathname;
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-100 backdrop-blur-md bg-opacity-95">
  <nav class="container-wide py-4 md:py-6 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 text-xl font-semibold tracking-tight hover:opacity-70 transition-opacity">
      <img
        src="/images/uipix-logo.webp"
        alt="UiPix Logo"
        class="h-8 w-8 rounded-lg"
      />
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-8">
      <a
        href="/"
        class={`text-sm font-medium transition-colors ${currentPath === '/' ? 'text-accent' : 'text-gray-700 hover:text-black'}`}
      >
        Work
      </a>
      <a
        href="/about"
        class={`text-sm font-medium transition-colors ${currentPath === '/about' ? 'text-accent' : 'text-gray-700 hover:text-black'}`}
      >
        About
      </a>
      <a
        href="/contact"
        class={`text-sm font-medium transition-colors ${currentPath === '/contact' ? 'text-accent' : 'text-gray-700 hover:text-black'}`}
      >
        Contact
      </a>
      <a
        href="https://linkedin.com/in/payalbhutani"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-gray-700 hover:text-black transition-colors"
      >
        LinkedIn
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 hover:bg-gray-100 rounded-lg transition-colors"
      aria-label="Toggle menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
    <div class="container-wide py-4 flex flex-col gap-4">
      <a
        href="/"
        class="text-sm font-medium text-gray-700 hover:text-black py-2 transition-colors"
      >
        Work
      </a>
      <a
        href="/about"
        class="text-sm font-medium text-gray-700 hover:text-black py-2 transition-colors"
      >
        About
      </a>
      <a
        href="/contact"
        class="text-sm font-medium text-gray-700 hover:text-black py-2 transition-colors"
      >
        Contact
      </a>
      <a
        href="https://linkedin.com/in/payalbhutani"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-gray-700 hover:text-black py-2 transition-colors"
      >
        LinkedIn
      </a>
    </div>
  </div>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // Close menu when a link is clicked
  document.querySelectorAll('#mobile-menu a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });
</script>
