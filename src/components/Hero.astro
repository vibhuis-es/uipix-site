---
interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
}

const {
  title = "Hi, I'm Payal!",
  subtitle = "UX Designer focused on clarity and human-centered solutions",
  description = "I design digital products that solve real problems through research, collaboration, and thoughtful iteration. Based in Dallas, Texas working with teams worldwide.",
  image = "/images/profile-photo.webp",
  imageAlt = "Payal Bhutani"
} = Astro.props;
---

<section class="py-16 md:py-24 overflow-hidden">
  <div class="container-wide">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">
      <!-- Content -->
      <div data-animate class="opacity-0">
        <h1 class="mb-4 text-black">{title}</h1>
        <h2 class="text-xl md:text-2xl font-light text-gray-700 mb-6">{subtitle}</h2>
        <p class="text-gray-600 text-lg leading-relaxed max-w-xl">{description}</p>
      </div>

      <!-- Image -->
      <div data-animate class="opacity-0 flex justify-center md:justify-end">
        <div class="relative w-full max-w-md aspect-square">
          <div class="absolute inset-0 bg-gradient-to-br from-gray-100 to-gray-50 rounded-full"></div>
          <img
            src={image}
            alt={imageAlt}
            class="w-full h-full object-cover rounded-full shadow-lg"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes parallax {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(20px);
    }
  }

  img {
    animation: parallax 6s ease-in-out infinite;
  }
</style>
