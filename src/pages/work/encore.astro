<script>
  // Mobile image scroll gallery
  (function () {
    const gallery = document.getElementById('mobile-scroll-gallery');
    if (!gallery) return;
    const track = gallery.querySelector('.mobile-scroll-track') as HTMLElement;
    const imgs = gallery.querySelectorAll('.mobile-scroll-img') as NodeListOf<HTMLElement>;
    const dots = gallery.querySelectorAll('.mobile-dot') as NodeListOf<HTMLElement>;
    const total = imgs.length;
    if (!total || !track) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval>;
    let paused = false;

    function goTo(idx: number) {
      current = idx;
      const imgH = gallery.clientHeight;
      track.style.transform = `translateY(-${idx * imgH}px)`;
      dots.forEach((d, i) => {
        d.style.opacity = i === idx ? '1' : '0.4';
      });
    }

    function startAuto() {
      clearInterval(timer);
      timer = setInterval(() => {
        if (!paused) goTo((current + 1) % total);
      }, 2500);
    }

    gallery.addEventListener('mouseenter', () => { paused = true; });
    gallery.addEventListener('mouseleave', () => { paused = false; });

    dots.forEach((d) => {
      d.addEventListener('click', () => {
        goTo(parseInt((d as HTMLElement).dataset.dot || '0'));
      });
    });

    goTo(0);
    startAuto();
  })();
</script>
