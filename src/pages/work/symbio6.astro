---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Symbio6 - Coming Soon">
  <section class="py-32 md:py-40 flex items-center justify-center min-h-[60vh]">
    <div class="container-prose text-center" data-animate>
      <div class="opacity-0">
        <span class="text-sm font-semibold text-accent">Case Study</span>
        <h1 class="mt-4 mb-6">Symbio6</h1>
        <p class="text-xl text-gray-600 mb-8">Healthcare Platform (Coming Soon)</p>

        <div class="max-w-md mx-auto mb-12">
          <img
            src="/images/symbio6-placeholder.webp"
            alt="Symbio6"
            class="w-full h-auto rounded-lg shadow-lg"
          />
        </div>

        <div class="bg-blue-50 border border-blue-100 rounded-lg p-8 mb-8">
          <p class="text-gray-700 text-lg mb-4">
            A UX design project in the healthcare space focused on improving patient engagement and clinical workflows.
          </p>
          <p class="text-gray-600">
            This case study is currently being developed. Check back soon for the full project breakdown, design process, and impact metrics.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
          <div class="bg-white border border-gray-200 rounded-lg p-6">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Year</p>
            <p class="text-lg font-semibold text-gray-900">2020</p>
          </div>
          <div class="bg-white border border-gray-200 rounded-lg p-6">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Industry</p>
            <p class="text-lg font-semibold text-gray-900">Healthcare</p>
          </div>
          <div class="bg-white border border-gray-200 rounded-lg p-6">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Role</p>
            <p class="text-lg font-semibold text-gray-900">UX Designer</p>
          </div>
        </div>

        <div class="text-center">
          <a href="/" class="text-accent hover:text-blue-700 transition-colors font-semibold">
            ← Back to Work
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
