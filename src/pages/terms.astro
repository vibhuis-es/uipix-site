---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Terms of Use - UiPix">
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-5 md:px-8">
      <div data-animate class="opacity-0">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight mb-4">Terms of Use</h1>
        <p class="text-sm text-gray-400 mb-10">Last updated: March 9, 2026</p>
      </div>

      <div class="prose prose-gray max-w-none space-y-8" data-animate>
        <div class="opacity-0">
          <h2 class="text-xl font-semibold text-gray-900 mb-3">Agreement to Terms</h2>
          <p class="text-base text-gray-600 leading-relaxed">
            By accessing and using the UiPix website (uipix.dev), you agree to be bound by these Terms of Use. If you do not agree with any part of these terms, please do not use this website.
          </p>
        </div>

        <div class="opacity-0">
          <h2 class="text-xl font-semibold text-gray-900 mb-3">Intellectual Property</h2>
          <p class="text-base text-gray-600 leading-relaxed">
            All content on this website — including but not limited to text, images, case studies, designs, graphics, and code — is the property of Payal Bhutani / UiPix and is protected by copyright and intellectual property laws. You may not reproduce, distribute, or use any content without prior written permission.
          </p>
        </div>

        <div class="opacity-0">
          <h2 class="text-xl font-semibold text-gray-900 mb-3">Portfolio & Case Studies</h2>
          <p class="text-base text-gray-600 leading-relaxed">
            The case studies and project work displayed on this website are presented for portfolio purposes. Some project details may be modified or omitted to comply with non-disclosure agreements. The designs shown may include work created in collaboration with teams and clients.
          </p>
        </div>

        <div class="opacity-0">
          <h2 class="text-xl font-semibold text-gray-900 mb-3">Use of Website</h2>
          <p class="text-base text-gray-600 leading-relaxed mb-3">You agree not to:</p>
          <ul class="list-disc pl-5 space-y-1.5 text-base text-gray-600">
            <li>Use this website for any unlawful purpose</li>
            <li>Attempt to gain unauthorized access to any part of the website</li>
            <li>Copy, reproduce, or redistribute website content without permission</li>
            <li>Use automated tools to scrape or collect content from this website</li>
          </ul>
        </div>

        <div class="opacity-0">
          <h2 class="text-xl font-semibold text-gray-900 mb-3">Disclaimer</h2>
          <p class="text-base text-gray-600 leading-relaxed">
            This website and its contents are provided "as is" without warranties of any kind, either express or implied. UiPix does not guarantee that the website will be available at all times or free from errors.
          </p>
        </div>

        <div class="opacity-0">
          <h2 class="text-xl font-semibold text-gray-900 mb-3">Limitation of Liability</h2>
          <p class="text-base text-gray-600 leading-relaxed">
            UiPix shall not be liable for any damages arising from the use or inability to use this website or its content.
          </p>
        </div>

        <div class="opacity-0">
          <h2 class="text-xl font-semibold text-gray-900 mb-3">External Links</h2>
          <p class="text-base text-gray-600 leading-relaxed">
            This website may contain links to third-party websites. We are not responsible for the content or privacy practices of those external sites.
          </p>
        </div>

        <div class="opacity-0">
          <h2 class="text-xl font-semibold text-gray-900 mb-3">Changes to Terms</h2>
          <p class="text-base text-gray-600 leading-relaxed">
            We reserve the right to modify these terms at any time. Continued use of the website after changes constitutes acceptance of the updated terms.
          </p>
        </div>

        <div class="opacity-0">
          <h2 class="text-xl font-semibold text-gray-900 mb-3">Contact</h2>
          <p class="text-base text-gray-600 leading-relaxed">
            For questions about these Terms of Use, please contact us at
            <a href="mailto:payalbhutani26@gmail.com" class="text-accent hover:underline">payalbhutani26@gmail.com</a>.
