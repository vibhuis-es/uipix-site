---
interface Props {
  steps: string[];
}

const { steps } = Astro.props;
---

<nav class="process-bar sticky top-[65px] z-40 bg-white/95 backdrop-blur-md border-y border-gray-200 shadow-sm pt-5 pb-3.5 overflow-x-auto scrollbar-hide" aria-label="Design process">
  <div class="max-w-5xl mx-auto px-5 md:px-8">
    <ol class="flex items-center gap-1 sm:gap-2 min-w-max">
      {steps.map((step, i) => {
        const isLast = i === steps.length - 1;
        return (
          <li class="flex items-center">
            <a
              href={`#section-${i}`}
              class="process-step flex items-center gap-1.5 sm:gap-2 px-2.5 sm:px-3 py-1.5 rounded-full text-xs sm:text-sm font-medium transition-all whitespace-nowrap text-gray-400 hover:text-gray-600"
              data-step={i}
            >
              <span class="step-num w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0 bg-gray-200 text-gray-400 transition-all">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="hidden sm:inline">{step}</span>
            </a>
            {!isLast && (
              <div class="step-line w-4 sm:w-6 h-px mx-0.5 bg-gray-200 transition-all"></div>
            )}
          </li>
        );
      })}
    </ol>
  </div>
</nav>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar { display: none; }

  /* Active step */
  .process-step.is-active {
    background: #0656f6;
    color: #fff;
  }
  .process-step.is-active .step-num {
    background: rgba(255,255,255,0.2);
    color: #fff;
  }

  /* Past step */
  .process-step.is-past {
    background: rgba(6,86,246,0.1);
    color: #0656f6;
  }
  .process-step.is-past .step-num {
    background: #0656f6;
    color: #fff;
  }

  .step-line.is-past {
    background: #0656f6;
  }
</style>

<script>
  function initProcessBar() {
    const bar = document.querySelector('.process-bar');
    if (!bar) return;

    const steps = bar.querySelectorAll('.process-step') as NodeListOf<HTMLElement>;
    const lines = bar.querySelectorAll('.step-line') as NodeListOf<HTMLElement>;
    const sections = document.querySelectorAll('[id^="section-"]') as NodeListOf<HTMLElement>;
    if (!sections.length) return;

    function update() {
      const scrollY = window.scrollY + 200;
      let activeIndex = 0;

      sections.forEach((section, i) => {
        if (scrollY >= section.offsetTop) {
          activeIndex = i;
        }
      });

      steps.forEach((step, i) => {
        step.classList.remove('is-active', 'is-past');
        const num = step.querySelector('.step-num');
        if (i === activeIndex) {
          step.classList.add('is-active');
        } else if (i < activeIndex) {
          step.classList.add('is-past');
          if (num) num.textContent = '✓';
        } else {
          if (num) num.textContent = String(i + 1).padStart(2, '0');
        }
      });

      lines.forEach((line, i) => {
        line.classList.toggle('is-past', i < activeIndex);
      });
    }

    window.addEventListener('scroll', update, { passive: true });
    update();
  }

  initProcessBar();
  document.addEventListener('astro:page-load', initProcessBar);
</script>
